    {
      "id": "5fbe02ec-46bd-40c2-b036-f2ba370069fb",
      "lessonId": "22475d69-5bea-403b-9fa5-901bcb654eb2",
      "groupId": "129606fd-55b0-4d29-a506-ec52f46f7819",
      "orderIndex": 2,
      "type": "text-slide",
      "propsJson": {
        "body": "Voilà le truc avec la prononciation dans n’importe quelle langue : tout dépend de la bouche. Les lèvres, la langue et la mâchoire donnent la forme au son. L’air vient de la poitrine, la vibration de la gorge — mais c’est bien la bouche qui fabrique le son.",
        "label": "La bouche",
        "allowSkip": false,
        "allowRetry": false,
        "isInteractive": false
      },
      "aidHook": null,
      "code": null,
