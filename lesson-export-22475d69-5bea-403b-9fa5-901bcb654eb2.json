      "orderIndex": 2,
      "type": "text-slide",
      "propsJson": {
        "body": "Une des raisons pour lesquelles les francophones ont du mal à se débarrasser de leur accent français en anglais, c’est qu’ils ne se détendent pas assez.",
        "label": "Français tendu",
        "allowSkip": false,
        "allowRetry": false,
        "isInteractive": false
      },
      "aidHook": null,
      "code": null,
      "metaJson": {},
