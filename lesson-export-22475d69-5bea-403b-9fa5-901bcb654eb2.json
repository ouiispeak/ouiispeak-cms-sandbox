    {
      "id": "51ab06a8-d4b3-4659-8126-9d2369926240",
      "lessonId": "22475d69-5bea-403b-9fa5-901bcb654eb2",
      "groupId": "56b09f6c-f4f0-4603-89f8-ed98a02422a0",
      "orderIndex": 3,
      "type": "text-slide",
      "propsJson": {
        "body": "Essaie ça : lis ces instructions à voix haute et fais bien attention à la façon dont ta bouche bouge. Ta langue est où ? Tes lèvres ? Et ta mâchoire, est-ce qu’elle est tendue ?",
        "label": "Parler et écouter",
        "allowSkip": false,
        "allowRetry": false,
        "isInteractive": false
      },
      "aidHook": null,
      "code": null,
      "metaJson": {},
      "isActivity": false,
