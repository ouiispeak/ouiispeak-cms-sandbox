    },
    {
      "id": "69a054e2-333e-4759-900b-9e7b4d69bca5",
      "lessonId": "22475d69-5bea-403b-9fa5-901bcb654eb2",
      "groupId": "129606fd-55b0-4d29-a506-ec52f46f7819",
      "orderIndex": 3,
      "type": "text-slide",
      "propsJson": {
        "body": "Pense au ski : si tu veux apprendre, tu dois d’abord prendre la bonne position. C’est pareil avec la prononciation : on entraîne la bouche petit à petit, pour qu’elle s’habitue aux sons anglais. Pas besoin d’être parfait — l’idée, c’est juste de créer une mémoire musculaire spéciale pour l’anglais.",
        "label": "Ski",
        "allowSkip": false,
        "allowRetry": false,
        "isInteractive": false
      },
      "aidHook": null,
      "code": null,
      "metaJson": {},
      "isActivity": false,
      "scoreType": "none",
