    },
    {
      "id": "ff6ac374-b645-40b4-ae62-4193c077b964",
      "lessonId": "22475d69-5bea-403b-9fa5-901bcb654eb2",
      "groupId": "bd5bda49-30ef-40cb-ad60-41a9ed558783",
      "orderIndex": 3,
      "type": "text-slide",
      "propsJson": {
        "body": "Essaie donc de garder la langue plutôt plate et de la pousser un peu vers l’avant pour laisser une sortie nette entre tes dents. Essaie de lire ce texte à voix haute et concentre-toi sur le fait de faire atterrir l’avion en toute sécurité.",
        "label": "Essaie ceci",
        "allowSkip": false,
        "allowRetry": false,
        "isInteractive": false
      },
      "aidHook": null,
      "code": null,
      "metaJson": {},
      "isActivity": false,
      "scoreType": "none",
